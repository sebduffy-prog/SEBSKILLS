// artist.config — the single per-artist config surface for a Recording Studio.
// Written by the `recording-studio` skill. Threaded into lib/brandColors.js, _document.jsx,
// the header call-site, lib/audiences.js, the API-route constants, and the keyword taxonomies.
// Env vars live in Vercel, NOT here. Anything you don't have yet → leave default / omit and ship "awaiting data".
{
  "artist": {
    "name": "Muse",
    "campaignName": "The Wow! Signal",
    "studioName": "The Recording Studio",          // PulseParticleText wordmark
    "kicker": "VCCP Media Cultural Intelligence",   // FIXED agency brand — do not change per artist
    "loginPassword": "muse2026",                    // replaces the client gate literal
    "wordmark": { "top": "MUSE", "bottom": "THE WOW! SIGNAL" }  // MuseDistortionWordmark props
  },

  "brand": {
    "primary": "#E30613",        // -> WMG_RED (brandColors.js)
    "primaryDeep": "#8A0008",    // -> WMG_RED_DEEP
    "bg": "#0C0C0C",             // dark shell — usually keep
    "font": {
      "family": "Inter Tight",
      "googleFontsUrl": "https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700;800;900&display=swap"
    },
    "backgroundImage": "/artist_bg.png",
    // Keep these per-component (chart series are load-bearing); listed for reference only:
    "dataVizPalette": ["#2DD4BF", "#A78BFA", "#FB923C", "#F472B6", "#34D399", "#F59E0B", "#FFD500"]
  },

  // Depth level shortcut: Lite = dashboard+audience+strategy; Standard adds media/music/social/tactics/calendar; Full = all
  "tabs": {
    "dashboard": true, "media": true, "music": true, "reddit": true, "audience": true,
    "strategy": true, "tactics": true, "ideas": true, "calendar": true, "locations": true,
    "research": true, "socialDashboard": false
  },

  // MUST match GWI CSV column order (totals, then these keys, left-to-right). Count = segment count.
  "audiences": [
    { "key": "segA", "label": "Segment A", "color": "#E30613" }
    // add 1..N segments
  ],

  // SOAP comms pillars — drive the Locations map layers and the Calendar blocks. Set first.
  "commsPillars": [
    { "id": "tease",   "title": "Tease",   "role": "...", "audience": "..." },
    { "id": "release", "title": "Release", "role": "...", "audience": "..." },
    { "id": "sustain", "title": "Sustain", "role": "...", "audience": "..." }
  ],

  // SOAP (Strategy on a Page) + POAP (Plan on a Page) content. Leave defaults / awaiting-data if no deck yet.
  "strategy": {
    "objectives":   [ { "tag": "Objective 01", "label": "...", "kpi": "...", "sub": "...", "copy": "..." } ],
    "growthLevers": [ { "num": "01", "title": "...", "question": "...", "insight": "...", "task": "..." } ],
    "executions":   [ { "label": "...", "copy": "..." } ]   // POAP "How"
  },

  "campaignWindow": { "start": "2026-05-01", "end": "2026-07-31" },

  "dataSources": {
    "spotifyArtistId": "12Chz98pHFMPJEknJQMWvI",
    "lastfmArtist": "Muse",
    "youtubeChannelId": "UCOcX2KyQxdtA4QppwLs_DlA",
    "wikipediaPages": ["Muse_(band)"],
    "googleTrendsTerms": ["Muse band", "The Wow! Signal"],
    "gdeltQuery": "\"muse\" (\"matt bellamy\" OR album OR tour)",
    "mediaIndexQueries": [ { "q": "Muse band", "label": "Muse" } ],
    "appleMusicMatcher": "muse"               // isMuse() substring rule
  },

  // Social listening is a PLUGGABLE, provider-agnostic adapter — swap per artist/campaign. Do not hardwire a vendor.
  "socialListening": {
    "provider": "brand24",                    // brand24 | brandwatch | talkwalker | sprout | meltwater | custom | upload
    "credentialsEnv": ["BRAND24_API_KEY", "BRAND24_PROJECT_ID"],  // whichever the chosen provider needs
    "uploadFallback": "Market Research/mentions.csv",             // used when no live API
    "ownedChannels": { "reddit": true, "youtube": true }         // corpus + keyword-taxonomy path
    // Adapter contract: return normalised { mentions, sentiment, volume, themes } for the ticker + dashboard.
  },

  "taxonomies": {
    "redditThemes":  [ { "id": "tour", "keywords": ["tour", "tickets"] } ],
    "youtubeThemes": [ { "id": "musical", "keywords": ["voice", "riff"] } ],
    "sentiment": { "positive": ["love", "legend"], "negative": ["overrated", "flop"] }
  },

  // Build-time inputs placed in /Market Research (each try/caught to [] so absence = awaiting-data)
  "marketResearchFiles": {
    "gwi": ["gwi_demographics.csv", "gwi_music.csv", "gwi_media.csv"],
    "youtubeComments": ["youtube_comments_bank_1.csv"],
    "redditPosts": "r_<artist>_posts_shrunk.csv",
    "redditComments": "r_<artist>_comments_shrunk.csv"
  },

  // Set in Vercel, never committed:
  "env": [
    "BRAVE_API_KEY", "SPOTIFY_CLIENT_ID", "SPOTIFY_CLIENT_SECRET", "ANTHROPIC_API_KEY",
    "YOUTUBE_API_KEY", "BRAND24_API_KEY", "BRAND24_PROJECT_ID", "LASTFM_API_KEY", "BLOB_READ_WRITE_TOKEN"
  ]
}
